# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# FreeImage.host API Key (Optional - has default key)
# Get your own free API key from: https://freeimage.host/page/api
# A default key is included, but you can replace it with your own
VITE_FREEIMAGE_API_KEY=6d207e02198a847aa98d0a2a901485a5

# Optional: Base path for deployment (e.g., if deploying to a subdirectory)
# VITE_BASE_PATH=/

# Development mode flag (used by Vite config)
# NODE_ENV=development
